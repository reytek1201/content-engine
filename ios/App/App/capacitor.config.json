{
	"appId": "co.slidepress.app",
	"appName": "SlidePress",
	"webDir": "capacitor-www",
	"appendUserAgent": "SlidePressApp/1",
	"server": {
		"url": "https://www.slidepress.co",
		"androidScheme": "https",
		"allowNavigation": [
			"slidepress.co",
			"www.slidepress.co",
			"*.slidepress.co",
			"*.supabase.co"
		]
	},
	"plugins": {
		"StatusBar": {
			"style": "DARK",
			"backgroundColor": "#09090b"
		}
	},
	"packageClassList": [
		"MediaPlugin",
		"AppPlugin",
		"CAPBrowserPlugin",
		"FilesystemPlugin",
		"SharePlugin",
		"StatusBarPlugin",
		"NativeAppleSignInPlugin"
	]
}
