# Supabase — https://supabase.com/dashboard/project/_/settings/api
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Google Gemini — https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your-gemini-api-key

# Fal.ai — https://fal.ai/dashboard/keys
FAL_KEY=your-fal-key

# Shared secret for Fal webhook authentication (random hex, min 32 chars)
FAL_WEBHOOK_SECRET=generate-with-node-crypto-randomBytes-32-toString-hex

# Production URL (no trailing slash) — used for webhook URLs and OAuth redirects
NEXT_PUBLIC_APP_URL=https://www.slidepress.co

# Firebase Cloud Messaging (optional — native push when campaign images finish)
# Create a Firebase project, enable Cloud Messaging, and upload your APNs key for iOS.
# Service account JSON from Firebase Console → Project settings → Service accounts.
# For Vercel, base64-encode the JSON file: base64 -i service-account.json | tr -d '\n'
# FCM_SERVICE_ACCOUNT_JSON=
# Or set these three variables instead:
# FIREBASE_PROJECT_ID=
# FIREBASE_CLIENT_EMAIL=
# FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"

# Dev only — show "Send test push" in Settings on native app (no image generation)
# Set to true on Vercel while testing push, then remove or set false for production.
# NEXT_PUBLIC_ALLOW_PUSH_TEST=true

# Marketing — optional overrides (defaults exist in public/marketing/)
# NEXT_PUBLIC_MARKETING_HERO_VIDEO_URL=/marketing/slidepress-hero.mp4
# NEXT_PUBLIC_MARKETING_HERO_POSTER_URL=/marketing/hero-poster.webp

# App download links — set when TestFlight public link or store listings are live
# NEXT_PUBLIC_APP_STORE_URL=https://testflight.apple.com/join/XXXXXXXX
# NEXT_PUBLIC_APP_STORE_URL=https://apps.apple.com/app/idXXXXXXXX
# NEXT_PUBLIC_PLAY_STORE_URL=https://play.google.com/store/apps/details?id=co.slidepress.app
